APP_NAME="E-Auction API"
ENVIRONMENT="development"

# Database
DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5432/eauction"

# WebSockets / Cache (if used in future)
REDIS_URL="redis://localhost:6379/0"

# Security
JWT_SECRET_KEY="your-super-secret-key-for-local-development-change-in-prod"
JWT_ALGORITHM="HS256"
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS
CORS_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"
